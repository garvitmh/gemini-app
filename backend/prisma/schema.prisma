generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Shop {
  id              String           @id @default(cuid())
  domain          String           @unique
  accessToken     String
  scope           String
  isActive        Boolean          @default(true)
  installedAt     DateTime         @default(now())
  uninstalledAt   DateTime?
  timezone        String           @default("UTC")
  currency        String           @default("INR")
  auditLogs       AuditLog[]
  automationRules AutomationRule[]
  enamelColors    EnamelColor[]
  enamelRates     EnamelRate[]
  metalRates      MetalRate[]
  products        Product[]
  settings        ShopSettings?
  stoneRates      StoneRate[]

  @@index([domain])
}

model ShopSettings {
  id                           String   @id @default(cuid())
  shopId                       String   @unique
  defaultMakingPerGram         Float    @default(1500)
  defaultWastagePct            Float    @default(0)
  defaultGstPct                Float    @default(3)
  defaultDiscount              Float    @default(0)
  defaultMakingChargeType      String   @default("per_gram")
  defaultMakingChargeValue     Float    @default(1500)
  defaultMetalDiscountType     String   @default("none")
  defaultMetalDiscountValue    Float    @default(0)
  defaultMakingDiscountType    String   @default("none")
  defaultMakingDiscountValue   Float    @default(0)
  defaultGemstoneDiscountType  String   @default("none")
  defaultGemstoneDiscountValue Float    @default(0)
  defaultEnamelDiscountType    String   @default("none")
  defaultEnamelDiscountValue   Float    @default(0)
  rateUpdateMode               String   @default("manual")
  rateSource                   String   @default("manual")
  rateSourceUrl                String?
  emailNotifications           Boolean  @default(true)
  notificationEmail            String?
  webhookUrl                   String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  shop                         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model MetalRate {
  id          String   @id @default(cuid())
  shopId      String
  metal       String
  karat       Int?
  purity      Float?
  ratePerGram Float
  rateSource  String   @default("manual")
  updatedBy   String?
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, metal, karat])
  @@index([shopId, updatedAt])
}

model StoneRate {
  id                String   @id @default(cuid())
  shopId            String
  stoneType         String
  naturalOrLabgrown String?
  quality           String?
  shape             String?
  cut               String?
  color             String?
  clarity           String?
  caratRange        String?
  unitType          String   @default("carat")
  ratePerCarat      Float?
  ratePerPiece      Float?
  ratePerGram       Float?
  updatedBy         String?
  reason            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, stoneType])
}

model EnamelRate {
  id          String   @id @default(cuid())
  shopId      String
  enamelColor String
  ratePerGram Float
  updatedBy   String?
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, enamelColor])
}

model EnamelColor {
  id        String   @id @default(cuid())
  shopId    String
  colorName String
  hexCode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model ProductGemstone {
  id                 String   @id @default(cuid())
  productId          String
  gemstoneType       String
  naturalOrLabgrown  String?
  quality            String?
  shape              String?
  gemstoneCut        String?
  gemstoneColor      String?
  gemstoneClarity    String?
  gemstoneCaratRange String?
  gemstoneWeight     Float?
  gemstonePieces     Int?
  unitType           String   @default("carat")
  discountType       String?
  discountValue      Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Product {
  id                    String            @id @default(cuid())
  shopId                String
  shopifyProductId      String
  shopifyVariantId      String            @unique
  sku                   String?
  title                 String
  variantTitle          String?
  imageUrl              String?
  status                String?
  weightGrams           Float?
  metal                 String?
  karat                 Int?
  stoneWeightCarat      Float?
  stoneType             String?
  stonePieces           Int?
  gemstoneType          String?
  gemstoneCut           String?
  gemstoneColor         String?
  gemstoneClarity       String?
  gemstoneCaratRange    String?
  isManualGemstonePrice Boolean           @default(false)
  manualGemstoneWeight  Float?
  manualGemstonePrice   Float?
  useCustomFormula      Boolean           @default(false)
  customFormula         String?
  makingChargeFlat      Float?
  makingChargePct       Float?
  wastagePct            Float?
  gstPct                Float?
  discount              Float?
  currentPrice          Float?
  lastCalculatedPrice   Float?
  lastPushedPrice       Float?
  lastPushedAt          DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  enamelColor           String?
  enamelDiscountType    String?
  enamelDiscountValue   Float?
  enamelWeightGrams     Float?
  gemstoneDiscountType  String?
  gemstoneDiscountValue Float?
  makingChargeType      String?
  makingChargeValue     Float?
  makingDiscountType    String?
  makingDiscountValue   Float?
  metalDiscountType     String?
  metalDiscountValue    Float?
  gemstoneQuality       String?
  gemstoneShape         String?
  naturalOrLabgrown     String?
  priceBreakdownHtml    String?
  priceHistory          PriceHistory[]
  shop                  Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  gemstones             ProductGemstone[]

  @@index([shopId, shopifyProductId])
  @@index([shopId, sku])
}

model PriceHistory {
  id           String   @id @default(cuid())
  productId    String
  oldPrice     Float?
  newPrice     Float
  pushedAt     DateTime @default(now())
  status       String
  errorMessage String?
  triggeredBy  String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, pushedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  shopId    String
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  reason    String?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, action])
}

model AutomationRule {
  id               String    @id @default(cuid())
  shopId           String
  enabled          Boolean   @default(false)
  triggerType      String
  thresholdPercent Float?
  schedule         String?
  autoRecalculate  Boolean   @default(true)
  autoPush         Boolean   @default(false)
  lastRun          DateTime?
  lastRunStatus    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  shop             Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, enabled])
}

model Job {
  id             String    @id @default(cuid())
  shopId         String
  jobType        String
  status         String
  totalItems     Int?
  processedItems Int?
  failedItems    Int?
  result         String?
  error          String?
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  @@index([shopId, status])
  @@index([createdAt])
}
