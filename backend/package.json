{
    "name": "metal-gem-price-editor",
    "version": "1.0.0",
    "description": "Shopify App for managing live metal and gem prices for jewelry stores",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "ts-node prisma/seed.ts",
        "test": "jest",
        "test:integration": "jest --config jest.integration.config.js"
    },
    "keywords": [
        "shopify",
        "app",
        "jewelry",
        "pricing",
        "gold",
        "diamond"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^5.7.0",
        "@shopify/shopify-api": "^9.0.0",
        "@shopify/shopify-app-express": "^3.0.0",
        "axios": "^1.6.2",
        "bull": "^4.12.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "csv-parse": "^6.1.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "graphql": "^16.8.1",
        "graphql-request": "^6.1.0",
        "ioredis": "^5.3.2",
        "multer": "^2.0.2",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.7",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@shopify/cli": "^3.52.0",
        "@types/bull": "^4.10.0",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.10.5",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.14",
        "nodemon": "^3.0.2",
        "prisma": "^5.7.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
