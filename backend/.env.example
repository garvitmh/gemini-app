# Environment
NODE_ENV=development

# Server
PORT=3000
# IMPORTANT: Set this to your actual public URL (Cloudflare Tunnel, Render, etc.)
# Shopify requires a public HTTPS URL for OAuth callback
HOST=https://your-tunnel-or-app-url.example.com

# Shopify App Credentials (from Shopify Partners Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_ACCESS_TOKEN=your_access_token_here

# Your Shopify Store Domain
SHOPIFY_STORE=your-store.myshopify.com

# OAuth Scopes
SCOPES=read_products,write_products,read_inventory,write_inventory

# Database (SQLite for dev, PostgreSQL recommended for production)
DATABASE_URL=file:./prisma/dev.db

# Session
SESSION_SECRET=change_this_to_a_random_secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
