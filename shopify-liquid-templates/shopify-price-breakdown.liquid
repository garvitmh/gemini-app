{% comment %}
  Gemini App - Price Breakdown Display for Shopify
  
  This snippet displays a detailed price breakdown for jewelry products.
  The breakdown data is stored in the product variant metafield: gemini.price_breakdown
  
  Installation:
  1. Add this code to your product template (e.g., product-template.liquid or main-product.liquid)
  2. Place it where you want the price breakdown to appear (typically after the product price)
  3. Make sure your products have the gemini.price_breakdown metafield populated
{% endcomment %}

{% assign current_variant = variant | default: product.selected_or_first_available_variant %}
{% assign breakdown = current_variant.metafields.gemini.price_breakdown.value %}

{% if breakdown %}
  <div class="gemini-price-breakdown" style="margin-top: 20px; border: 1px solid #e1e3e5; border-radius: 8px; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    
    <h3 style="background-color: #f9fafb; margin: 0; padding: 12px 16px; font-size: 16px; border-bottom: 1px solid #e1e3e5; font-weight: 600;">
      Price Breakdown
    </h3>
    
    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tbody>
        
        {% comment %} Product Details Overview {% endcomment %}
        <tr style="border-bottom: 2px solid #e1e3e5; background-color: #fcfcfc;">
          <td colspan="2" style="padding: 12px 16px;">
            <div style="margin-bottom: 6px; font-weight: 600; font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px;">Product Details</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 13px; color: #4b5563;">
              <div><strong style="color: #111827;">Net Weight:</strong> {{ breakdown.weight | default: '0' }} g</div>
              <div><strong style="color: #111827;">Purity:</strong> {{ breakdown.metal_name | default: 'N/A' }}</div>
              <div><strong style="color: #111827;">Variant Color:</strong> {{ current_variant.title | replace: 'Default Title', 'Standard' }}</div>
              <div><strong style="color: #111827;">Wastage:</strong> {{ breakdown.wastage_pct | default: '0' }}%</div>
            </div>
          </td>
        </tr>

        {% comment %} Metal Price Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            {{ breakdown.metal_name | default: 'Metal' }} Price
            {% if breakdown.has_metal_discount %}
              <span style="margin-left:8px; font-size:11px; color:#d93025; background:#fee2e2; padding:1px 5px; border-radius:3px; font-weight:600; text-transform:uppercase;">Sale</span>
            {% endif %}
            <div style="font-size: 12px; color: #6b7280;">
              (₹{{ breakdown.metal_rate | divided_by: 100.0 | round: 2 }}/g)
            </div>
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            {% if breakdown.has_metal_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                Rs. {{ breakdown.metal_value_original | divided_by: 100.0 | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.metal_value | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Wastage Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            Wastage ({{ breakdown.wastage_pct }}%)
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            Rs. {{ breakdown.wastage_amount | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Making Charges Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            Making Charges
            {% if breakdown.has_making_discount %}
              <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
            {% endif %}
            <div style="font-size: 12px; color: #6b7280;">
              {% if breakdown.making_charge_type == 'percent' %}
                {{ breakdown.making_charge_rate }}% of value
              {% elsif breakdown.making_charge_type == 'flat' %}
                Flat Rate
              {% else %}
                ₹{{ breakdown.making_charge_rate }}/g
              {% endif %}
            </div>
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            {% if breakdown.has_making_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                Rs. {{ breakdown.making_charges_original | divided_by: 100.0 | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.making_charges | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Multiple Gemstones Support {% endcomment %}
        {% if breakdown.gemstone_details.type == 'multiple' and breakdown.gemstone_details.gemstones %}
          {% for gem in breakdown.gemstone_details.gemstones %}
            <tr style="border-bottom: 1px solid #f1f2f3;">
              <td style="padding: 10px 16px; color: #374151;">
                {% assign gem_type_lower = gem.type | downcase %}
                {% if gem_type_lower contains 'cz' or gem_type_lower contains 'cubic zirconia' %}
                   {% assign unit = 'gm' %}
                {% else %}
                   {% assign unit = 'ct' %}
                {% endif %}
                
                {{ gem.type | replace: '_', ' ' }}
                {% if gem.clarity %}({{ gem.clarity }}){% endif %}
                {% if gem.color %}{{ gem.color }}{% endif %}
                {% if gem.cut %}{{ gem.cut }}{% endif %}
                {% if gem.hasDiscount %}
                  <span style="margin-left:8px; font-size:11px; color:#d93025; background:#fee2e2; padding:1px 5px; border-radius:3px; font-weight:600; text-transform:uppercase;">Sale</span>
                {% endif %}
                {% if gem.rateNotSet %}
                  <div style="font-size: 12px; color: #d93025; font-weight: 600;">⚠️ Rate not set</div>
                {% elsif gem.weight %}
                  {% assign gem_rate = gem.cost | divided_by: gem.weight | divided_by: 100 | round %}
                  <div style="font-size: 12px; color: #6b7280;">{{ gem.weight }}{{ unit }} × ₹{{ gem_rate }}/{{ unit }}</div>
                {% elsif gem.pieces %}
                  {% assign gem_rate = gem.cost | divided_by: gem.pieces | divided_by: 100 | round %}
                  <div style="font-size: 12px; color: #6b7280;">{{ gem.pieces }} pcs × ₹{{ gem_rate }}/pc</div>
                {% endif %}
              </td>
              <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
                {% if gem.rateNotSet %}
                  <span style="color: #d93025;">Rs. 0.00</span>
                {% else %}
                  {% if gem.hasDiscount %}
                    <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                      Rs. {{ gem.cost | divided_by: 100.0 | round: 2 }}
                    </div>
                  {% endif %}
                  Rs. {{ gem.finalCost | divided_by: 100.0 | round: 2 }}
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          
          {% comment %} Total Gemstones Row (if multiple) {% endcomment %}
          {% if breakdown.gemstone_details.gemstones.size > 1 %}
            <tr style="border-bottom: 1px solid #f1f2f3; background-color: #f9fafb;">
              <td style="padding: 10px 16px; color: #374151; font-weight: 600;">Total Gemstones</td>
              <td style="padding: 10px 16px; text-align: right; font-weight: 600;">
                Rs. {{ breakdown.gemstone_price | divided_by: 100.0 | round: 2 }}
              </td>
            </tr>
          {% endif %}
        
        {% comment %} Single Gemstone (Fallback) {% endcomment %}
        {% elsif breakdown.gemstone_price > 0 or breakdown.gemstone_price_original > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #374151;">
              {{ breakdown.gemstone_name | default: 'Gemstone' | replace: '_', ' ' }}
              {% if breakdown.has_gemstone_discount %}
                <span style="margin-left:8px; font-size:11px; color:#d93025; background:#fee2e2; padding:1px 5px; border-radius:3px; font-weight:600; text-transform:uppercase;">Sale</span>
              {% endif %}
              
              {% assign gem_name_lower = breakdown.gemstone_name | downcase %}
              {% if gem_name_lower contains 'cz' or gem_name_lower contains 'cubic zirconia' %}
                 {% assign unit = 'gm' %}
              {% else %}
                 {% assign unit = 'ct' %}
              {% endif %}

              {% if breakdown.gemstone_details.type == 'per_carat' %}
                <div style="font-size: 12px; color: #6b7280;">
                  {{ breakdown.gemstone_details.weight }}{{ unit }} × ₹{{ breakdown.gemstone_details.rate | divided_by: 1 | round: 2 }}/{{ unit }}
                </div>
              {% elsif breakdown.gemstone_details.type == 'per_piece' %}
                <div style="font-size: 12px; color: #6b7280;">
                  {{ breakdown.gemstone_details.pieces }} pcs × ₹{{ breakdown.gemstone_details.rate | divided_by: 1 | round: 2 }}/pc
                </div>
              {% elsif breakdown.gemstone_details.type == 'manual' %}
                <div style="font-size: 11px; color: #6b7280; font-weight: 400;">Gemstone Pricing Source: Manual (Per Piece)</div>
              {% else %}
                <div style="font-size: 11px; color: #6b7280; font-weight: 400;">Gemstone Pricing Source: Rate-Based</div>
              {% endif %}
            </td>
            <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
              {% if breakdown.has_gemstone_discount %}
                <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                  Rs. {{ breakdown.gemstone_price_original | divided_by: 100.0 | round: 2 }}
                </div>
              {% endif %}
              Rs. {{ breakdown.gemstone_price | divided_by: 100.0 | round: 2 }}
            </td>
          </tr>
        {% endif %}
        
        {% comment %} Enamel Row {% endcomment %}
        {% if breakdown.enamel_price > 0 or breakdown.enamel_price_original > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #374151;">
              {{ breakdown.enamel_name | default: 'Enamel' | replace: '_', ' ' }}
              {% if breakdown.has_enamel_discount %}
                <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
              {% endif %}
              {% if breakdown.enamel_details.type == 'per_gram' %}
                <div style="font-size: 12px; color: #6b7280;">
                  {{ breakdown.enamel_details.weight }}g × ₹{{ breakdown.enamel_details.rate | divided_by: 1 }}/g
                </div>
              {% endif %}
            </td>
            <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
              {% if breakdown.has_enamel_discount %}
                <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                  Rs. {{ breakdown.enamel_price_original | divided_by: 100.0 | round: 2 }}
                </div>
              {% endif %}
              Rs. {{ breakdown.enamel_price | divided_by: 100.0 | round: 2 }}
            </td>
          </tr>
        {% endif %}
        
        {% comment %} Subtotal Row {% endcomment %}
        <tr style="background-color: #fafbfb; border-top: 1px solid #e1e3e5;">
          <td style="padding: 8px 16px; font-weight: 600; color: #374151;">Subtotal</td>
          <td style="padding: 8px 16px; text-align: right; font-weight: 600; color: #374151;">
            Rs. {{ breakdown.subtotal | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
        {% comment %} GST Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">GST ({{ breakdown.gst_pct }}%)</td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            {% assign gst_value = breakdown.gst_amount | default: 0 %}
            Rs. {{ gst_value | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Shop Discount Row {% endcomment %}
        {% if breakdown.discount > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #d93025;">Shop Discount</td>
            <td style="padding: 10px 16px; text-align: right; color: #d93025;">
              -Rs. {{ breakdown.discount | divided_by: 100.0 | round: 2 }}
            </td>
          </tr>
        {% endif %}

        {% comment %} Product Discount Row {% endcomment %}
        {% if breakdown.product_discount > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #d93025;">Product Discount</td>
            <td style="padding: 10px 16px; text-align: right; color: #d93025;">
              -Rs. {{ breakdown.product_discount | divided_by: 100.0 | round: 2 }}
            </td>
          </tr>
        {% endif %}

        
        {% comment %} Final Price Row {% endcomment %}
        <tr style="background-color: #f0fdf4;">
          <td style="padding: 14px 16px; font-weight: 700; color: #166534; font-size: 16px;">Final Price</td>
          <td style="padding: 14px 16px; text-align: right; font-weight: 700; color: #166534; font-size: 16px;">
            {% if breakdown.has_any_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 11px; font-weight: 400;">
                Rs. {{ breakdown.total_original | divided_by: 100.0 | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.total | divided_by: 100.0 | round: 2 }}
          </td>
        </tr>
        
      </tbody>
    </table>
    
    <div style="margin-top: 8px; padding: 8px 16px; font-size: 12px; color: #6b7280; text-align: center;">
      Prices are subject to change based on market rates.
    </div>
    
  </div>
{% endif %}

<style>
  /* Responsive styling for mobile devices */
  @media (max-width: 768px) {
    .gemini-price-breakdown table {
      font-size: 13px !important;
    }
    .gemini-price-breakdown td {
      padding: 8px 12px !important;
    }
    .gemini-price-breakdown h3 {
      font-size: 15px !important;
      padding: 10px 12px !important;
    }
  }
</style>
