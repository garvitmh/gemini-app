{% comment %}
  Gemini App - Price Breakdown Display for Shopify
  
  This snippet displays a detailed price breakdown for jewelry products.
  The breakdown data is stored in the product variant metafield: gemini.price_breakdown
  
  Installation:
  1. Copy this entire code
  2. Go to Shopify Admin → Online Store → Themes → Actions → Edit code
  3. Find your product template file (usually sections/main-product.liquid or templates/product.liquid)
  4. Paste this code where you want the price breakdown to appear (typically after the product price)
  5. Click Save
{% endcomment %}

{% assign breakdown = product.selected_or_first_available_variant.metafields.gemini.price_breakdown %}

{% if breakdown %}
  <div class="gemini-price-breakdown" style="margin-top: 20px; border: 1px solid #e1e3e5; border-radius: 8px; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    
    <h3 style="background-color: #f9fafb; margin: 0; padding: 12px 16px; font-size: 16px; border-bottom: 1px solid #e1e3e5; font-weight: 600;">
      Price Breakdown
    </h3>
    
    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tbody>
        
        {% comment %} Metal Price Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            {{ breakdown.metal_name | default: 'Metal' }} Price
            {% if breakdown.has_metal_discount %}
              <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
            {% endif %}
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            {% if breakdown.has_metal_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                Rs. {{ breakdown.metal_value_original | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.metal_value | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Wastage Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            Wastage ({{ breakdown.wastage_pct }}%)
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            Rs. {{ breakdown.wastage_amount | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Making Charges Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            Making Charges
            {% if breakdown.has_making_discount %}
              <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
            {% endif %}
            <div style="font-size: 12px; color: #6b7280;">
              {% if breakdown.making_charge_type == 'percent' %}
                {{ breakdown.making_charge_rate }}% of value
              {% elsif breakdown.making_charge_type == 'flat' %}
                Flat Rate
              {% else %}
                ₹{{ breakdown.making_charge_rate }}/g
              {% endif %}
            </div>
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            {% if breakdown.has_making_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                Rs. {{ breakdown.making_charges_original | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.making_charges | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Multiple Gemstones Support {% endcomment %}
        {% if breakdown.gemstone_details.type == 'multiple' and breakdown.gemstone_details.gemstones %}
          {% for gem in breakdown.gemstone_details.gemstones %}
            <tr style="border-bottom: 1px solid #f1f2f3;">
              <td style="padding: 10px 16px; color: #374151;">
                {% if gem.type == 'cz' or gem.type == 'CZ' or gem.type == 'c_z' %}
                  CZ Cubic Zirconia
                {% else %}
                  {{ gem.type | replace: '_', ' ' }}
                {% endif %}
                {% if gem.clarity %}({{ gem.clarity }}){% endif %}
                {% if gem.color %}{{ gem.color }}{% endif %}
                {% if gem.cut %}{{ gem.cut }}{% endif %}
                {% if gem.hasDiscount %}
                  <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
                {% endif %}
                {% if gem.rateNotSet %}
                  <div style="font-size: 12px; color: #d93025; font-weight: 600;">⚠️ Rate not set</div>
                {% elsif gem.weight %}
                  {% assign gem_rate = gem.cost | divided_by: gem.weight | divided_by: 100 | round %}
                  <div style="font-size: 12px; color: #6b7280;">{{ gem.weight }}ct × ₹{{ gem_rate }}/ct</div>
                {% elsif gem.pieces %}
                  {% assign gem_rate = gem.cost | divided_by: gem.pieces | divided_by: 100 | round %}
                  <div style="font-size: 12px; color: #6b7280;">{{ gem.pieces }} pcs × ₹{{ gem_rate }}/pc</div>
                {% endif %}
              </td>
              <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
                {% if gem.rateNotSet %}
                  <span style="color: #d93025;">Rs. 0.00</span>
                {% else %}
                  {% if gem.hasDiscount %}
                    <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                      Rs. {{ gem.cost | round: 2 }}
                    </div>
                  {% endif %}
                  Rs. {{ gem.finalCost | round: 2 }}
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          
          {% comment %} Total Gemstones Row (if multiple) {% endcomment %}
          {% if breakdown.gemstone_details.gemstones.size > 1 %}
            <tr style="border-bottom: 1px solid #f1f2f3; background-color: #f9fafb;">
              <td style="padding: 10px 16px; color: #374151; font-weight: 600;">Total Gemstones</td>
              <td style="padding: 10px 16px; text-align: right; font-weight: 600;">
                Rs. {{ breakdown.gemstone_price | round: 2 }}
              </td>
            </tr>
          {% endif %}
        
        {% comment %} Single Gemstone (Fallback) {% endcomment %}
        {% elsif breakdown.gemstone_price and breakdown.gemstone_price > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #374151;">
              {{ breakdown.gemstone_name | default: 'Gemstone' | replace: '_', ' ' }}
              {% if breakdown.has_gemstone_discount %}
                <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
              {% endif %}
            </td>
            <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
              {% if breakdown.has_gemstone_discount %}
                <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                  Rs. {{ breakdown.gemstone_price_original | round: 2 }}
                </div>
              {% endif %}
              Rs. {{ breakdown.gemstone_price | round: 2 }}
            </td>
          </tr>
        {% endif %}
        
        {% comment %} Enamel Row (if exists) {% endcomment %}
        {% if breakdown.enamel_price and breakdown.enamel_price > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #374151;">
              {{ breakdown.enamel_name | default: 'Enamel' | replace: '_', ' ' }}
              {% if breakdown.has_enamel_discount %}
                <span style="margin-left: 8px; font-size: 12px; color: #d93025; background: #fee2e2; padding: 2px 6px; border-radius: 4px;">Sale</span>
              {% endif %}
            </td>
            <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
              {% if breakdown.has_enamel_discount %}
                <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px;">
                  Rs. {{ breakdown.enamel_price_original | round: 2 }}
                </div>
              {% endif %}
              Rs. {{ breakdown.enamel_price | round: 2 }}
            </td>
          </tr>
        {% endif %}
        
        {% comment %} Subtotal Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3; background-color: #f9fafb;">
          <td style="padding: 10px 16px; color: #374151; font-weight: 600;">
            Subtotal
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 600;">
            Rs. {{ breakdown.subtotal | round: 2 }}
          </td>
        </tr>
        
        {% comment %} GST Row {% endcomment %}
        <tr style="border-bottom: 1px solid #f1f2f3;">
          <td style="padding: 10px 16px; color: #374151;">
            GST ({{ breakdown.gst_pct }}%)
          </td>
          <td style="padding: 10px 16px; text-align: right; font-weight: 500;">
            Rs. {{ breakdown.gst_amount | round: 2 }}
          </td>
        </tr>
        
        {% comment %} Shop Discount Row {% endcomment %}
        {% if breakdown.discount > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #d93025;">Shop Discount</td>
            <td style="padding: 10px 16px; text-align: right; color: #d93025;">
              Rs. {{ breakdown.discount | round: 2 }}
            </td>
          </tr>
        {% endif %}

        {% comment %} Product Discount Row {% endcomment %}
        {% if breakdown.product_discount > 0 %}
          <tr style="border-bottom: 1px solid #f1f2f3;">
            <td style="padding: 10px 16px; color: #d93025;">Product Discount</td>
            <td style="padding: 10px 16px; text-align: right; color: #d93025;">
              Rs. {{ breakdown.product_discount | round: 2 }}
            </td>
          </tr>
        {% endif %}

        <tr style="background-color: #f0fdf4;">
          <td style="padding: 12px 16px; color: #166534; font-weight: 600; font-size: 15px;">
            Final Price
          </td>
          <td style="padding: 12px 16px; text-align: right; font-weight: 600; font-size: 15px; color: #166534;">
            {% if breakdown.has_any_discount %}
              <div style="text-decoration: line-through; color: #9ca3af; font-size: 12px; font-weight: 400;">
                Rs. {{ breakdown.total_original | round: 2 }}
              </div>
            {% endif %}
            Rs. {{ breakdown.total | round: 2 }}
          </td>
        </tr>
        
      </tbody>
    </table>
    
    <div style="padding: 10px 16px; background-color: #fafafa; border-top: 1px solid #e1e3e5; font-size: 12px; color: #6b7280; text-align: center;">
      Prices are subject to change based on market rates.
    </div>
    
  </div>
{% endif %}
